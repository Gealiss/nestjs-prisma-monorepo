{
  "name": "@repo/database",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "db:migrate:local": "dotenv -e .env.local -o -- prisma migrate dev",
    "db:migrate:test": "dotenv -e .env.test -o -- prisma migrate dev",
    "db:migrate:local:create-only": "dotenv -e .env.local -o -- prisma migrate dev --create-only",
    "db:migrate:dev": "dotenv -e .env.dev -o -- prisma migrate deploy",
    "db:migrate:prod": "dotenv -e .env.prod -o -- prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:generate:watch": "prisma generate --watch",
    "db:push": "prisma db push",
    "dev": "concurrently \"tsup src --watch\" \"pnpm db:generate:watch\"",
    "check-types": "tsc --noEmit",
    "build": "rimraf dist src/generated && prisma generate && tsc"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.0.10",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
