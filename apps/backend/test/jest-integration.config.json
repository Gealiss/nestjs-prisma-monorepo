{
  "rootDir": "../src",
  "modulePaths": ["<rootDir>"],
  "moduleFileExtensions": ["js", "json", "ts"],
  "moduleNameMapper": {
    "@/(.*)": "<rootDir>/$1"
  },
  "testEnvironment": "node",
  "testRegex": ".*\\.integration\\.test\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFiles": ["../test/setup-integration-tests.ts"]
}
